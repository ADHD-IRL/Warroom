# ──────────────────────────────────────────────
# Warroom – environment variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# PostgreSQL connection string (required)
# Local example: postgresql://postgres:postgres@localhost:5432/warroom
DATABASE_URL=postgresql://user:password@localhost:5432/warroom

# Anthropic API key (required) – get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Port the API server (and dev frontend) listen on (default: 3000)
PORT=3000

# Base path for the frontend – use "/" for root deployments (default: /)
BASE_PATH=/
